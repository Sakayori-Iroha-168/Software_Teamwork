digraph ER {
  graph [
    charset="UTF-8",
    label="智能问答系统 ER 图（优化逻辑模型）",
    labelloc=t,
    fontsize=24,
    fontname="Microsoft YaHei",
    rankdir=TB,
    bgcolor="white",
    pad=0.35,
    nodesep=0.45,
    ranksep=0.85,
    splines=ortho,
    overlap=false,
    newrank=true
  ];
  node [shape=plain, fontname="Microsoft YaHei", fontsize=9.2];
  edge [fontname="Microsoft YaHei", fontsize=8.5, color="#526D82", penwidth=1.15, arrowsize=0.7];

  subgraph cluster_chat {
    label="对话与流式问答";
    color="#9DC3E6";
    style="rounded";
    fontname="Microsoft YaHei";
    fontsize=14;

    conversations [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#2F5D7C">
        <TR><TD BGCOLOR="#5B9BD5"><FONT COLOR="white"><B>conversations 会话</B></FONT></TD></TR>
        <TR><TD ALIGN="LEFT">PK id : uuid</TD></TR>
        <TR><TD ALIGN="LEFT">EXT external_user_id : varchar</TD></TR>
        <TR><TD ALIGN="LEFT">title : varchar</TD></TR>
        <TR><TD ALIGN="LEFT">status : active / archived</TD></TR>
        <TR><TD ALIGN="LEFT">created_at / updated_at / deleted_at?</TD></TR>
      </TABLE>
    >];

    messages [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#2F5D7C">
        <TR><TD BGCOLOR="#5B9BD5"><FONT COLOR="white"><B>messages 对话消息</B></FONT></TD></TR>
        <TR><TD ALIGN="LEFT">PK id : uuid</TD></TR>
        <TR><TD ALIGN="LEFT">FK conversation_id</TD></TR>
        <TR><TD ALIGN="LEFT">role : user / assistant / system</TD></TR>
        <TR><TD ALIGN="LEFT">sequence_no : integer</TD></TR>
        <TR><TD ALIGN="LEFT">status : streaming / completed / stopped / failed</TD></TR>
        <TR><TD ALIGN="LEFT">model_name? / error_code? / error_message?</TD></TR>
        <TR><TD ALIGN="LEFT">created_at / completed_at?</TD></TR>
        <TR><TD ALIGN="LEFT"><I>UK(conversation_id, sequence_no)</I></TD></TR>
      </TABLE>
    >];

    response_runs [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#2F5D7C">
        <TR><TD BGCOLOR="#4472C4"><FONT COLOR="white"><B>response_runs 问答运行</B></FONT></TD></TR>
        <TR><TD ALIGN="LEFT">PK id : uuid</TD></TR>
        <TR><TD ALIGN="LEFT">FK conversation_id</TD></TR>
        <TR><TD ALIGN="LEFT">FK user_message_id</TD></TR>
        <TR><TD ALIGN="LEFT">FK assistant_message_id?</TD></TR>
        <TR><TD ALIGN="LEFT">FK qa_config_version_id / llm_config_version_id</TD></TR>
        <TR><TD ALIGN="LEFT">request_id : varchar (幂等/追踪)</TD></TR>
        <TR><TD ALIGN="LEFT">intent_type / route / confidence?</TD></TR>
        <TR><TD ALIGN="LEFT">status / stop_reason / retry_count</TD></TR>
        <TR><TD ALIGN="LEFT">prompt / completion / reasoning tokens</TD></TR>
        <TR><TD ALIGN="LEFT">latency_ms / started_at / finished_at?</TD></TR>
      </TABLE>
    >];

    message_blocks [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#2F5D7C">
        <TR><TD BGCOLOR="#9DC3E6"><B>message_content_blocks 消息内容块</B></TD></TR>
        <TR><TD ALIGN="LEFT">PK id : uuid</TD></TR>
        <TR><TD ALIGN="LEFT">FK message_id</TD></TR>
        <TR><TD ALIGN="LEFT">block_order : integer</TD></TR>
        <TR><TD ALIGN="LEFT">block_type : text / displayable_reasoning / tool*</TD></TR>
        <TR><TD ALIGN="LEFT">content : text</TD></TR>
        <TR><TD ALIGN="LEFT">status : streaming / completed / stopped</TD></TR>
        <TR><TD ALIGN="LEFT">provider_block_id? / provider_metadata? : jsonb</TD></TR>
        <TR><TD ALIGN="LEFT">created_at / updated_at</TD></TR>
        <TR><TD ALIGN="LEFT"><I>UK(message_id, block_order)</I></TD></TR>
      </TABLE>
    >];

    process_steps [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#2F5D7C">
        <TR><TD BGCOLOR="#BDD7EE"><B>response_process_steps 展示型处理步骤</B></TD></TR>
        <TR><TD ALIGN="LEFT">PK id : uuid</TD></TR>
        <TR><TD ALIGN="LEFT">FK response_run_id</TD></TR>
        <TR><TD ALIGN="LEFT">step_order / step_type</TD></TR>
        <TR><TD ALIGN="LEFT">label / detail? / status</TD></TR>
        <TR><TD ALIGN="LEFT">started_at / finished_at?</TD></TR>
        <TR><TD ALIGN="LEFT"><I>仅保存可向用户展示的步骤，不保存私有思维链</I></TD></TR>
      </TABLE>
    >];

    stream_events [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#2F5D7C">
        <TR><TD BGCOLOR="#D9EAF7"><B>response_stream_events SSE事件（短期）</B></TD></TR>
        <TR><TD ALIGN="LEFT">PK id : bigint</TD></TR>
        <TR><TD ALIGN="LEFT">FK response_run_id</TD></TR>
        <TR><TD ALIGN="LEFT">event_seq : integer</TD></TR>
        <TR><TD ALIGN="LEFT">event_type : intent / step / token / citation / done / error</TD></TR>
        <TR><TD ALIGN="LEFT">payload : jsonb</TD></TR>
        <TR><TD ALIGN="LEFT">created_at / expires_at</TD></TR>
        <TR><TD ALIGN="LEFT"><I>UK(response_run_id, event_seq)</I></TD></TR>
      </TABLE>
    >];

    citations [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#2F5D7C">
        <TR><TD BGCOLOR="#BDD7EE"><B>citations 引用快照</B></TD></TR>
        <TR><TD ALIGN="LEFT">PK id : uuid</TD></TR>
        <TR><TD ALIGN="LEFT">FK message_id</TD></TR>
        <TR><TD ALIGN="LEFT">citation_no / char_start? / char_end?</TD></TR>
        <TR><TD ALIGN="LEFT">EXT external_kb_id / external_doc_id / external_chunk_id</TD></TR>
        <TR><TD ALIGN="LEFT">doc_name / quote_text / context?</TD></TR>
        <TR><TD ALIGN="LEFT">page_number? / score? / metadata? : jsonb</TD></TR>
        <TR><TD ALIGN="LEFT"><I>保存回答时快照；原文件由外部文件服务下载</I></TD></TR>
      </TABLE>
    >];
  }

  subgraph cluster_config {
    label="运行配置与管理";
    color="#A9D18E";
    style="rounded";
    fontname="Microsoft YaHei";
    fontsize=14;

    qa_config [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#548235">
        <TR><TD BGCOLOR="#70AD47"><FONT COLOR="white"><B>qa_config_versions 问答配置版本</B></FONT></TD></TR>
        <TR><TD ALIGN="LEFT">PK id : uuid</TD></TR>
        <TR><TD ALIGN="LEFT">UK version_no : bigint</TD></TR>
        <TR><TD ALIGN="LEFT">top_k / similarity_threshold</TD></TR>
        <TR><TD ALIGN="LEFT">use_rerank / rerank_threshold / rerank_top_n</TD></TR>
        <TR><TD ALIGN="LEFT">is_active / created_at</TD></TR>
        <TR><TD ALIGN="LEFT">EXT created_by_user_id</TD></TR>
      </TABLE>
    >];

    qa_config_kb [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#548235">
        <TR><TD BGCOLOR="#C6E0B4"><B>qa_config_knowledge_bases 配置知识库</B></TD></TR>
        <TR><TD ALIGN="LEFT">PK/FK config_id</TD></TR>
        <TR><TD ALIGN="LEFT">PK EXT external_kb_id</TD></TR>
        <TR><TD ALIGN="LEFT">kb_type : terminology / technical_supervision</TD></TR>
        <TR><TD ALIGN="LEFT">display_name_snapshot? / sort_order</TD></TR>
      </TABLE>
    >];

    llm_config [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#548235">
        <TR><TD BGCOLOR="#70AD47"><FONT COLOR="white"><B>llm_config_versions LLM配置版本</B></FONT></TD></TR>
        <TR><TD ALIGN="LEFT">PK id : uuid</TD></TR>
        <TR><TD ALIGN="LEFT">UK version_no : bigint</TD></TR>
        <TR><TD ALIGN="LEFT">provider / api_url / model_name</TD></TR>
        <TR><TD ALIGN="LEFT">api_key_secret_ref / api_key_last4</TD></TR>
        <TR><TD ALIGN="LEFT">timeout_seconds / temperature / max_tokens</TD></TR>
        <TR><TD ALIGN="LEFT">is_active / created_at</TD></TR>
        <TR><TD ALIGN="LEFT"><I>密钥正文存密钥服务；留空更新表示保持原值</I></TD></TR>
      </TABLE>
    >];

    audit_logs [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#7F6000">
        <TR><TD BGCOLOR="#F4B183"><B>admin_audit_logs 管理审计</B></TD></TR>
        <TR><TD ALIGN="LEFT">PK id : uuid</TD></TR>
        <TR><TD ALIGN="LEFT">EXT external_user_id</TD></TR>
        <TR><TD ALIGN="LEFT">action / target_type / target_id?</TD></TR>
        <TR><TD ALIGN="LEFT">before_data / after_data : jsonb</TD></TR>
        <TR><TD ALIGN="LEFT">request_id / ip_address? / created_at</TD></TR>
      </TABLE>
    >];
  }

  subgraph cluster_retrieval {
    label="检索体验测试";
    color="#FFD966";
    style="rounded";
    fontname="Microsoft YaHei";
    fontsize=14;

    retrieval_runs [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#806000">
        <TR><TD BGCOLOR="#FFD966"><B>retrieval_test_runs 检索测试运行</B></TD></TR>
        <TR><TD ALIGN="LEFT">PK id : uuid</TD></TR>
        <TR><TD ALIGN="LEFT">FK qa_config_version_id?</TD></TR>
        <TR><TD ALIGN="LEFT">EXT external_user_id</TD></TR>
        <TR><TD ALIGN="LEFT">query / overrides : jsonb</TD></TR>
        <TR><TD ALIGN="LEFT">status / result_count / latency_ms / error?</TD></TR>
        <TR><TD ALIGN="LEFT">created_at / finished_at?</TD></TR>
      </TABLE>
    >];

    retrieval_results [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#806000">
        <TR><TD BGCOLOR="#FFE699"><B>retrieval_test_results 检索测试结果</B></TD></TR>
        <TR><TD ALIGN="LEFT">PK id : uuid</TD></TR>
        <TR><TD ALIGN="LEFT">FK test_run_id</TD></TR>
        <TR><TD ALIGN="LEFT">rank_no</TD></TR>
        <TR><TD ALIGN="LEFT">EXT external_kb_id / doc_id / chunk_id</TD></TR>
        <TR><TD ALIGN="LEFT">doc_name / text_snapshot</TD></TR>
        <TR><TD ALIGN="LEFT">vector_score / rerank_score? / metadata? : jsonb</TD></TR>
      </TABLE>
    >];
  }

  legend [label=<
    <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5" COLOR="#999999">
      <TR><TD BGCOLOR="#F2F2F2"><B>图例与边界</B></TD></TR>
      <TR><TD ALIGN="LEFT">PK 主键；FK 本系统外键；EXT 外部系统标识，不建本地主数据表</TD></TR>
      <TR><TD ALIGN="LEFT">用户、角色、知识库、文档/文件由其他小组服务维护</TD></TR>
      <TR><TD ALIGN="LEFT">近30天问答统计由 response_runs 聚合，不重复建统计事实表</TD></TR>
      <TR><TD ALIGN="LEFT">* tool 内容块为兼容扩展，当前智能问答核心只需 text / displayable_reasoning</TD></TR>
    </TABLE>
  >];

  conversations -> messages [label="1 : 0..N"];
  conversations -> response_runs [label="1 : 0..N"];
  messages -> message_blocks [label="1 : 1..N"];
  messages -> citations [label="助手消息 1 : 0..N"];
  response_runs -> process_steps [label="1 : 0..N"];
  response_runs -> stream_events [label="1 : 0..N（短期）"];
  messages -> response_runs [label="用户/助手消息关联", style=dashed];

  qa_config -> qa_config_kb [label="1 : 1..N"];
  qa_config -> response_runs [label="配置快照 1 : 0..N"];
  llm_config -> response_runs [label="模型配置 1 : 0..N"];
  qa_config -> retrieval_runs [label="0..1 : 0..N"];
  retrieval_runs -> retrieval_results [label="1 : 0..N"];

  audit_logs -> qa_config [label="审计目标", style=dotted, arrowhead=none];
  audit_logs -> llm_config [label="审计目标", style=dotted, arrowhead=none];

  { rank=same; conversations; response_runs; }
  { rank=same; message_blocks; process_steps; stream_events; citations; }
  { rank=same; qa_config; llm_config; audit_logs; }
  { rank=same; retrieval_runs; retrieval_results; legend; }
}
