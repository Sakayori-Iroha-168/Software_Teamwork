# Local/demo integration settings for deploy/docker-compose.yml.
# These values are intentionally non-production examples.

POSTGRES_PORT=5432
POSTGRES_PASSWORD=local_dev_postgres_password
REDIS_PORT=6379
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

MINIO_ROOT_USER=localminio
MINIO_ROOT_PASSWORD=local-minio-password-change-me
MINIO_BUCKET_FILES=local-files
MINIO_BUCKET_DOCUMENTS=local-documents

INTERNAL_SERVICE_TOKEN=local-dev-service-token-change-me
INTERNAL_SERVICE_TOKEN_SHA256=1340e74cf9bef3aa359c458562f8fe87f4e549aecf98b7bba464560cd2b9fbc5

AUTH_HTTP_PORT=8001
AUTH_TOKEN_HASH_SECRET=local-auth-token-hash-secret-change-me
AUTH_SESSION_TTL=24h

GATEWAY_HTTP_PORT=8080
GATEWAY_TOKEN_HASH_SECRET=local-gateway-token-hash-secret-change-me
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:5173

FILE_HTTP_PORT=8082
FILE_STORAGE_BACKEND=local
FILE_LOCAL_STORAGE_DIR=/data/file-storage

KNOWLEDGE_HTTP_PORT=8083
KNOWLEDGE_SERVICE_VERSION=local-demo

QA_HTTP_PORT=8084
QA_CONFIG_ENCRYPTION_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f
QA_SETTINGS_OPEN=false
AGENT_WORKDIR=/workspace
AGENT_ENABLE_COMMAND_TOOL=false
MCP_TRANSPORT=disabled

DOCUMENT_HTTP_PORT=8085
DOCUMENT_AI_GATEWAY_PROFILE_ID=default-chat

AI_GATEWAY_HTTP_PORT=8086
AI_GATEWAY_CREDENTIAL_ENCRYPTION_KEY_REF=local-demo-key-v1
AI_GATEWAY_CREDENTIAL_ENCRYPTION_KEY=local-demo-credential-encryption-key-change-me

# Demo login seeded by deploy/seed/demo_seed.sql.
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=admin-local-password
