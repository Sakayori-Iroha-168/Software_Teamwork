# Production/staging deployment template. Values are placeholders only.
# Copy to a secret-managed environment outside git before deployment.

COMPOSE_PROJECT_NAME=software-teamwork-prod

# Published immutable image tags. Do not use :latest for production/staging.
FRONTEND_IMAGE=registry.example.com/software-teamwork/frontend:REPLACE_WITH_TAG
GATEWAY_IMAGE=registry.example.com/software-teamwork/gateway:REPLACE_WITH_TAG
AUTH_IMAGE=registry.example.com/software-teamwork/auth:REPLACE_WITH_TAG
FILE_IMAGE=registry.example.com/software-teamwork/file:REPLACE_WITH_TAG
PARSER_IMAGE=registry.example.com/software-teamwork/parser:REPLACE_WITH_TAG
KNOWLEDGE_IMAGE=registry.example.com/software-teamwork/knowledge:REPLACE_WITH_TAG
QA_IMAGE=registry.example.com/software-teamwork/qa:REPLACE_WITH_TAG
DOCUMENT_IMAGE=registry.example.com/software-teamwork/document:REPLACE_WITH_TAG
AI_GATEWAY_IMAGE=registry.example.com/software-teamwork/ai-gateway:REPLACE_WITH_TAG
MIGRATE_IMAGE=registry.example.com/software-teamwork/goose-migrate:REPLACE_WITH_TAG

# Pinned infrastructure image defaults. Override only with equivalent pinned
# enterprise mirror tags.
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
QDRANT_IMAGE=qdrant/qdrant:v1.18.2
MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2025-08-13T08-35-41Z

# Public ingress. Keep internal services on the Compose network.
FRONTEND_HTTP_PORT=80
GATEWAY_HTTP_PORT=8080
GATEWAY_PUBLIC_ORIGIN=https://example.invalid
GATEWAY_CORS_ALLOWED_ORIGINS=https://example.invalid

# PostgreSQL superuser and per-service database users. Replace every password.
# Current service DSNs are URL strings, so use URL-safe generated database
# passwords such as A-Z, a-z, 0-9, dot, underscore, tilde, or hyphen.
POSTGRES_PASSWORD=REPLACE_WITH_POSTGRES_ADMIN_PASSWORD
AUTH_DB_PASSWORD=REPLACE_WITH_AUTH_DB_PASSWORD
FILE_DB_PASSWORD=REPLACE_WITH_FILE_DB_PASSWORD
KNOWLEDGE_DB_PASSWORD=REPLACE_WITH_KNOWLEDGE_DB_PASSWORD
QA_DB_PASSWORD=REPLACE_WITH_QA_DB_PASSWORD
DOCUMENT_DB_PASSWORD=REPLACE_WITH_DOCUMENT_DB_PASSWORD
AI_GATEWAY_DB_PASSWORD=REPLACE_WITH_AI_GATEWAY_DB_PASSWORD

# Internal service credentials and token-hash material.
INTERNAL_SERVICE_TOKEN=REPLACE_WITH_RANDOM_INTERNAL_SERVICE_TOKEN
TOKEN_HASH_SECRET=REPLACE_WITH_RANDOM_TOKEN_HASH_SECRET
TOKEN_HASH_KEY_VERSION=v1
AI_GATEWAY_SERVICE_TOKEN_HASHES=sha256:REPLACE_WITH_SHA256_OF_INTERNAL_SERVICE_TOKEN

# Object storage. These are MinIO root credentials for this single-machine
# baseline; use a secret manager or environment injection in real deployments.
MINIO_ROOT_USER=REPLACE_WITH_MINIO_ROOT_USER
MINIO_ROOT_PASSWORD=REPLACE_WITH_MINIO_ROOT_PASSWORD
FILE_MINIO_BUCKET=software-teamwork-prod
FILE_MINIO_REGION=
FILE_MINIO_USE_SSL=false

# AI Gateway credential encryption. Provider API keys are not stored here; add
# provider credentials through AI Gateway admin/profile APIs after startup.
AI_GATEWAY_CREDENTIAL_ENCRYPTION_KEY_REF=REPLACE_WITH_KEY_REF
AI_GATEWAY_CREDENTIAL_ENCRYPTION_KEY=REPLACE_WITH_LONG_RANDOM_ENCRYPTION_KEY

# Gateway service configuration.
GATEWAY_ENV=production
GATEWAY_SERVICE_VERSION=REPLACE_WITH_RELEASE_VERSION
GATEWAY_REQUEST_TIMEOUT=30s
GATEWAY_DOWNSTREAM_TIMEOUT=10s
GATEWAY_MAX_BODY_BYTES=10485760
GATEWAY_REDIS_DB=0

# Auth service configuration.
AUTH_ENV=production
AUTH_SERVICE_VERSION=REPLACE_WITH_RELEASE_VERSION
AUTH_SESSION_TTL=24h
AUTH_DEFAULT_ROLE_CODE=standard

# File service configuration.
FILE_MAX_UPLOAD_BYTES=33554432
FILE_STORAGE_BACKEND=minio
FILE_MINIO_TIMEOUT=10s

# Parser runtime configuration.
PARSER_BACKEND=ppstructurev3
PARSER_PROFILE=accurate
PARSER_MAX_DOCUMENT_BYTES=20971520
PARSER_MAX_CONCURRENCY=1
PARSER_QUEUE_TIMEOUT_SECONDS=0
PARSER_PARSE_TIMEOUT_SECONDS=120
PARSER_LOAD_BACKEND_ON_STARTUP=false
PARSER_SUBPROCESS_ISOLATION=true
PARSER_MEMORY_LIMIT_MB=14500
PARSER_DEFAULT_DPI=180
PARSER_RETRY_DPI=220
PARSER_MAX_RETRY_DPI=300
PADDLEOCR_LANG=ch
PADDLEOCR_DEVICE=cpu
PADDLEOCR_CONFIG_PATH=

# Knowledge retrieval configuration.
KNOWLEDGE_ENV=production
KNOWLEDGE_SERVICE_VERSION=REPLACE_WITH_RELEASE_VERSION
KNOWLEDGE_MAX_UPLOAD_BYTES=33554432
EMBEDDING_PROVIDER=local_hashing
EMBEDDING_MODEL=local_hashing
EMBEDDING_DIMENSION=384
QDRANT_COLLECTION=knowledge_chunks
QDRANT_API_KEY=
AI_GATEWAY_EMBEDDING_PROFILE_ID=
RERANK_MODEL=
RERANK_PROFILE_ID=

# QA runtime configuration.
QA_CONFIG_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARACTER_KEY
QA_ADMIN_USER_IDS=
QA_SETTINGS_OPEN=false
AI_GATEWAY_PROFILE_ID=REPLACE_WITH_CHAT_PROFILE_ID
MODEL_ID=REPLACE_WITH_CHAT_PROFILE_MODEL
AI_GATEWAY_TIMEOUT=60s
AI_GATEWAY_STREAM=false
MCP_TRANSPORT=disabled
AGENT_WORKDIR=/workspace
AGENT_MAX_TOKENS=4096
AGENT_MAX_ITERATIONS=8
MCP_MAX_RESULT_BYTES=50000
AGENT_ENABLE_COMMAND_TOOL=false
QA_SESSION_ATTACHMENT_TTL_HOURS=24
QA_SESSION_ATTACHMENT_MAX_BYTES=20971520
QA_SESSION_ATTACHMENT_MAX_PER_SESSION=10
QA_SESSION_ATTACHMENT_PROCESS_TIMEOUT_SECONDS=60

# Document runtime configuration.
DOCUMENT_AI_GATEWAY_PROFILE_ID=REPLACE_WITH_CHAT_PROFILE_ID
DOCUMENT_PANDOC_PATH=pandoc
DOCUMENT_LIBREOFFICE_PATH=soffice

# AI Gateway runtime configuration.
AI_GATEWAY_SECRET_MODE=encrypted_column
AI_GATEWAY_DEFAULT_TIMEOUT_MS=60000
AI_GATEWAY_MAX_REQUEST_BYTES=1048576
